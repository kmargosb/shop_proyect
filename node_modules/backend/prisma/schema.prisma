generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ============================
 * USER
 * ============================
 */

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?
  name     String?
  role     Role    @default(USER)

  tokenVersion Int @default(0)

  loginAttempts Int       @default(0)
  lockUntil     DateTime?

  refreshTokens RefreshToken[]
  orders        Order[]

  createdAt DateTime @default(now())
}

/**
 * ============================
 * PRODUCT
 * ============================
 */

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?

  price Int
  stock Int

  isActive Boolean @default(true)
  
  images     ProductImage[]
  orderItems OrderItem[]


  createdAt DateTime @default(now())
}

/**
 * ============================
 * PRODUCT IMAGE
 * ============================
 */

model ProductImage {
  id       String @id @default(uuid())
  url      String
  publicId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

/**
 * ============================
 * ORDER
 * ============================
 */

model Order {
  id String @id @default(uuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  fullName String
  email    String
  phone    String

  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String
  country      String

  totalAmount Int
  currency    String @default("eur")

  stripePaymentIntentId String? @unique
  stripeCustomerId      String?

  status OrderStatus @default(PENDING)
  paidAt DateTime?

  items        OrderItem[]
  invoice      Invoice?
  refunds      Refund[]
  transactions OrderTransaction[]
  events       OrderEvent[]

  createdAt DateTime @default(now())
}

/**
 * ============================
 * ORDER ITEM
 * ============================
 */

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productName String?
  productSku  String?

  quantity Int
  price    Int

  refundItems RefundItem[]
}

/**
 * ============================
 * ORDER TRANSACTION
 * ============================
 */

model OrderTransaction {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type TransactionType

  amount   Int
  currency String

  stripePaymentIntentId String?
  stripeRefundId        String?

  createdAt DateTime @default(now())
}

/*
 * ============================
 * OrderEvent
 * ============================
 */

model OrderEvent {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type OrderEventType

  message String?

  createdAt DateTime @default(now())
}

/*
 * ============================
 * REFUND
 * ============================
 */

model Refund {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  stripeRefundId String? @unique

  amount   Int
  currency String

  reason RefundReason?
  note   String?

  status RefundStatus @default(PENDING)

  items RefundItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ============================
 * REFUND ITEM
 * ============================
 */

model RefundItem {
  id String @id @default(uuid())

  refundId String
  refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  quantity Int
  amount   Int

  createdAt DateTime @default(now())
}

/**
 * ============================
 * REFRESH TOKEN
 * ============================
 */

model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime
}

/**
 * ============================
 * INVOICE
 * ============================
 */

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  customerEmail String
  totalAmount   Int

  createdAt DateTime @default(now())
}

model InvoiceSequence {
  id        String   @id @default(uuid())
  year      Int      @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
}

/**
 * ============================
 * ENUMS
 * ============================
 */

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAYMENT_PROCESSING
  PAID
  SHIPPED
  CANCELLED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum RefundReason {
  CUSTOMER_RETURN
  DAMAGED
  WRONG_ITEM
  FRAUD
  ORDER_CANCELLED
  OTHER
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum OrderEventType {
  ORDER_CREATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_CREATED
  REFUND_COMPLETED
  ORDER_CANCELLED
  ORDER_SHIPPED
  ORDER_UPDATED
}