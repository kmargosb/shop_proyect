generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?
  name     String?
  role     Role    @default(USER)

  tokenVersion Int @default(0)

  loginAttempts Int       @default(0)
  lockUntil     DateTime?

  refreshTokens RefreshToken[]
  orders        Order[]
  carts         Cart[]

  provider String?

  addresses Address[] // 🔥 NUEVO (IMPORTANTE)

  createdAt DateTime @default(now())
}

/*
 * ============================
 * BRAND
 * ============================
 */

model Brand {
  id    String @id @default(cuid())
  name  String
  slug  String @unique

  products Product[]

  createdAt DateTime @default(now())
}

/*
 * ============================
 * PRODUCT
 * ============================
 */

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?

  price Int

  stock         Int
  reservedStock Int @default(0)

  reservations InventoryReservation[]

  isActive Boolean @default(true)

  /* ============================
     BRAND (NEW - SAFE)
  ============================ */

  brandId String?
  brand   Brand? @relation(fields: [brandId], references: [id])

  /* ============================
     RELATIONS
  ============================ */

  images     ProductImage[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())

  @@index([brandId])
}

/**
 * ============================
 * PRODUCT IMAGE
 * ============================
 */

model ProductImage {
  id       String @id @default(uuid())
  url      String
  publicId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

/**
 * ============================
 * CART
 * ============================
 */

model Cart {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items CartItem[]

  status CartStatus @default(ACTIVE)

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ============================
 * CART ITEM
 * ============================
 */

model CartItem {
  id String @id @default(uuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Int 

  createdAt DateTime @default(now())

  @@index([cartId])
}

/**
 * ============================
 * Reservation
 * ============================
 */

model InventoryReservation {
  id String @id @default(uuid())

  productId String
  orderId   String

  quantity Int

  expiresAt DateTime

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@unique([productId, orderId])
  @@index([productId, expiresAt])
}

/**
 * ============================
 * ORDER
 * ============================
 */

model Order {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  fullName String
  email    String
  phone    String

  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String
  country      String

  totalAmount Int
  currency    String @default("eur")

  paymentSessions PaymentSession[]

  paymentProvider PaymentProvider @default(STRIPE)
  paymentMethod   PaymentMethod?

  stripePaymentIntentId String? @unique
  stripeCustomerId      String?

  status OrderStatus @default(PENDING)
  paidAt DateTime?

  abandonedEmailStage Int @default(0)

  items        OrderItem[]
  invoice      Invoice?
  refunds      Refund[]
  transactions OrderTransaction[]
  events       OrderEvent[]

  reservations InventoryReservation[]

  shipment Shipment?

  createdAt DateTime @default(now())
}

/**
 * ============================
 * Shipment
 * ============================
 */

model Shipment {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  carrier        String
  trackingNumber String

  status ShipmentStatus @default(PENDING)

  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
}

/**
 * ============================
 * ORDER ITEM
 * ============================
 */

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productName String?
  productSku  String?

  quantity Int
  price    Int

  refundItems RefundItem[]
}

/**
 * ============================
 * PaymentSession
 * ============================
 */

model PaymentSession {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  method   PaymentMethod

  paymentIntentId String?

  status PaymentSessionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ============================
 * ORDER TRANSACTION
 * ============================
 */

model OrderTransaction {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type TransactionType

  amount   Int
  currency String

  stripePaymentIntentId String?
  stripeRefundId        String?

  createdAt DateTime @default(now())
}

/**
 * ============================
 * OrderEvent
 * ============================
 */

model OrderEvent {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type OrderEventType

  message String?

  createdAt DateTime @default(now())
}

/**
 * ============================
 * REFUND
 * ============================
 */

model Refund {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  stripeRefundId String? @unique

  amount   Int
  currency String

  reason RefundReason?
  note   String?

  status RefundStatus @default(PENDING)

  items RefundItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * ============================
 * REFUND ITEM
 * ============================
 */

model RefundItem {
  id String @id @default(uuid())

  refundId String
  refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  quantity Int
  amount   Int

  createdAt DateTime @default(now())
}

/**
 * ============================
 * REFRESH TOKEN
 * ============================
 */

model RefreshToken {
  id    String @id @default(uuid())
  token String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime
}

/**
 * ============================
 * INVOICE
 * ============================
 */

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  customerEmail String
  totalAmount   Int

  createdAt DateTime @default(now())
}

model InvoiceSequence {
  id        String   @id @default(uuid())
  year      Int      @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
}

model Address {
  id           String   @id @default(cuid())
  userId       String

  fullName     String
  phone        String

  addressLine1 String
  addressLine2 String?

  city         String
  postalCode   String
  country      String

  isDefault    Boolean @default(false)

  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId]) // 🔥 rendimiento (déjalo)
}

model Coupon {
  id String @id @default(uuid())

  code String @unique

  type CouponType

  value Int

  minOrderAmount Int?

  maxUses   Int?
  usedCount Int  @default(0)

  expiresAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

/*
 * ============================
 * STRIPE WEBHOOK EVENT
 * ============================
 */

model StripeWebhookEvent {
  id String @id

  createdAt DateTime @default(now())

  @@index([createdAt])
}

/**
 * ============================
 * ENUMS
 * ============================
 */

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAYMENT_PROCESSING
  PAID
  SHIPPED
  CANCELLED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum RefundReason {
  CUSTOMER_RETURN
  DAMAGED
  WRONG_ITEM
  FRAUD
  ORDER_CANCELLED
  OTHER
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum OrderEventType {
  ORDER_CREATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_CREATED
  REFUND_COMPLETED
  ORDER_CANCELLED
  ORDER_SHIPPED
  ORDER_UPDATED
}

enum PaymentSessionStatus {
  PENDING
  ACTIVE
  FAILED
  COMPLETED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  KLARNA
}

enum PaymentMethod {
  CARD
  PAYPAL
  KLARNA
  BIZUM
  APPLE_PAY
  GOOGLE_PAY
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  MERGED
}