{
  "name": "proyecto",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.8.9"
  },
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND,STRIPE,REDIS -c blue,green,yellow,magenta \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:stripe\" \"npm run dev:redis\"",
    "dev:frontend": "npm --workspace=frontend run dev",
    "dev:backend": "npm --workspace=backend run dev",
    "dev:stripe": "stripe listen --forward-to localhost:4000/api/payments/webhook",
    "dev:redis": "docker start redis",
    "dev:prisma": "npm --workspace=backend exec prisma studio"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.94.5"
  }
}
