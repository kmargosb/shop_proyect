generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String?
  name          String?
  role          Role           @default(USER)
  lockUntil     DateTime?
  loginAttempts Int            @default(0)
  tokenVersion  Int            @default(0)
  createdAt     DateTime       @default(now())
  provider      String?
  marketingEmails Boolean @default(true)
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  wishlistItems      WishlistItem[]
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String           @id @default(uuid())
  name        String
  price       Int
  createdAt   DateTime         @default(now())
  description String?
  isActive    Boolean          @default(true)
  brandId     String?
  category    ProductCategory  @default(OTHER)
  gender      ProductGender    @default(UNISEX)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  brand       Brand?           @relation(fields: [brandId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  wishlistItems WishlistItem[]

  @@index([brandId])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  publicId  String
  productId String
  createdAt DateTime @default(now())
  isPrimary Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id            String                 @id @default(uuid())
  productId     String
  size          ProductSize
  color         ProductColor
  stock         Int                    @default(0)
  reservedStock Int                    @default(0)
  sku           String?
  createdAt     DateTime               @default(now())
  cartItems     CartItem[]
  reservations  InventoryReservation[]
  orderItems    OrderItem[]
  product       Product                @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String?
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime        @default(now())
  price     Int
  variantId String?
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([variantId])
}

model InventoryReservation {
  id        String         @id @default(uuid())
  orderId   String
  quantity  Int
  expiresAt DateTime
  createdAt DateTime       @default(now())
  variantId String
  order     Order          @relation(fields: [orderId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([variantId, orderId])
  @@index([variantId, expiresAt])
}

model Order {
  id                    String                 @id @default(uuid())
  userId                String?
  status                OrderStatus            @default(PENDING)
  createdAt             DateTime               @default(now())
  addressLine1          String
  addressLine2          String?
  city                  String
  country               String
  email                 String
  fullName              String
  phone                 String
  postalCode            String
  currency              String                 @default("eur")
  paidAt                DateTime?
  stripeCustomerId      String?
  stripePaymentIntentId String?                @unique
  totalAmount           Int
  paymentProvider       PaymentProvider        @default(STRIPE)
  paymentMethod         PaymentMethod?
  abandonedEmailStage   Int                    @default(0)
  reservations          InventoryReservation[]
  invoice               Invoice?
  user                  User?                  @relation(fields: [userId], references: [id])
  OrderChangeRequest    OrderChangeRequest[]
  events                OrderEvent[]
  items                 OrderItem[]
  transactions          OrderTransaction[]
  paymentSessions       PaymentSession[]
  refunds               Refund[]
  shipment              Shipment?
}

model Shipment {
  id             String         @id @default(uuid())
  orderId        String         @unique
  carrier        String
  trackingNumber String
  status         ShipmentStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String          @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  price       Int
  productName String?
  productSku  String?
  color       ProductColor?
  size        ProductSize?
  variantId   String?
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  refundItems RefundItem[]

  @@index([variantId])
}

model PaymentSession {
  id              String               @id @default(uuid())
  orderId         String
  provider        PaymentProvider
  method          PaymentMethod
  paymentIntentId String?
  status          PaymentSessionStatus @default(PENDING)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  order           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderTransaction {
  id                    String          @id @default(uuid())
  orderId               String
  type                  TransactionType
  amount                Int
  currency              String
  stripePaymentIntentId String?
  stripeRefundId        String?
  createdAt             DateTime        @default(now())
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderEvent {
  id        String         @id @default(uuid())
  orderId   String
  type      OrderEventType
  message   String?
  createdAt DateTime       @default(now())
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id              String           @id @default(uuid())
  orderId         String
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripeRefundId  String?          @unique
  amount          Int
  currency        String
  type            RefundType       @default(CUSTOMER_RETURN)
  reason          RefundReason?
  note            String?
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
  carrier         String?
  trackingNumber  String?
  customerSentAt  DateTime?
  status          RefundStatus     @default(PENDING_REVIEW)
  items           RefundItem[]
  evidence        RefundEvidence[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RefundEvidence {
  id        String   @id @default(uuid())
  refundId  String
  url       String
  publicId  String?
  createdAt DateTime @default(now())
  refund    Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
}

model RefundItem {
  id          String    @id @default(uuid())
  refundId    String
  orderItemId String
  quantity    Int
  amount      Int
  createdAt   DateTime  @default(now())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  refund      Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  orderId       String   @unique
  customerEmail String
  createdAt     DateTime @default(now())
  totalAmount   Int
  order         Order    @relation(fields: [orderId], references: [id])
}

model InvoiceSequence {
  id        String   @id @default(uuid())
  year      Int      @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String
  country      String
  createdAt    DateTime @default(now())
  isDefault    Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Coupon {
  id             String     @id @default(uuid())
  code           String     @unique
  type           CouponType
  value          Int
  minOrderAmount Int?
  maxUses        Int?
  usedCount      Int        @default(0)
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
}

model StripeWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AdminSettings {
  id                     String   @id @default("singleton")
  storeName              String   @default("Shop Proyect")
  supportEmail           String   @default("support@shopproyect.com")
  domain                 String   @default("shopproyect.com")
  country                String   @default("España")
  currency               String   @default("EUR")
  taxRate                Decimal  @default(21) @db.Decimal(5, 2)
  taxLabel               String   @default("IVA")
  showTaxes              Boolean  @default(true)
  shippingZone           String   @default("EU shipping zone")
  estimatedDelivery      String   @default("2-5 días laborables")
  trackingAutomatic      Boolean  @default(false)
  emailFromName          String   @default("Shop Proyect")
  emailFromAddress       String   @default("no-reply@shopproyect.com")
  orderConfirmationEmail Boolean  @default(true)
  theme                  String   @default("Dark premium")
  accentColor            String   @default("Emerald / Indigo")
  themeEditorPrepared    Boolean  @default(false)
  notifyOrders           Boolean  @default(true)
  notifyStock            Boolean  @default(true)
  notifyRefunds          Boolean  @default(true)
  notifyWeekly           Boolean  @default(false)
  compactTableDensity    Boolean  @default(false)
  keyboardShortcuts      Boolean  @default(true)
  autoRefreshDashboard   Boolean  @default(true)
  maintenanceMode        Boolean  @default(false)
  webhookEndpoint        String   @default("https://shopproyect.com/api/webhooks")
  apiKeysLabel           String   @default("Secret management pending")
  refundAutomation       Boolean  @default(false)
  shipmentTracking       Boolean  @default(false)
  invoiceActions         Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model OrderChangeRequest {
  id             String                   @id
  orderId        String
  type           OrderChangeRequestType
  status         OrderChangeRequestStatus @default(PENDING)
  currentValue   String?
  requestedValue String?
  note           String?
  createdAt      DateTime                 @default(now())
  reviewedAt     DateTime?
  Order          Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}



enum ProductCategory {
  T_SHIRTS
  SHIRTS
  TANK_TOPS
  PANTS
  SOCKS
  CAPS
  SKATE_DECKS
  TRUCKS
  BEARINGS
  WHEELS
  HARDWARE
  WAX
  STICKERS
  SPECIAL_ITEMS
  OTHER
}

enum ProductGender {
  MEN
  WOMEN
  UNISEX
}

enum ProductSize {
  XS
  S
  M
  L
  XL
  XXL
  ONE_SIZE
}

enum ProductColor {
  BLACK
  WHITE
  BEIGE
  GREY
  GREEN
  RED
  BLUE
  BROWN
  PINK
  YELLOW
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  PAYMENT_PROCESSING
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DELIVERED
}

enum RefundStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUCCEEDED
  FAILED
  RECEIVED
  CUSTOMER_SENT
}

enum RefundReason {
  CUSTOMER_RETURN
  DAMAGED
  WRONG_ITEM
  FRAUD
  ORDER_CANCELLED
  OTHER
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum OrderEventType {
  ORDER_CREATED
  PAYMENT_SUCCEEDED
  REFUND_CREATED
  REFUND_COMPLETED
  ORDER_CANCELLED
  ORDER_SHIPPED
  PAYMENT_FAILED
  ORDER_UPDATED
  ORDER_ADJUSTED
  ORDER_DELIVERED
  CUSTOMER_REQUESTED_SIZE_CHANGE
  CUSTOMER_REQUESTED_COLOR_CHANGE
  CUSTOMER_REQUESTED_PRODUCT_CHANGE
  CUSTOMER_REQUESTED_ADDRESS_CHANGE
}

enum PaymentSessionStatus {
  PENDING
  ACTIVE
  FAILED
  COMPLETED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  KLARNA
}

enum PaymentMethod {
  CARD
  PAYPAL
  KLARNA
  BIZUM
  APPLE_PAY
  GOOGLE_PAY
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  MERGED
}

enum OrderChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderChangeRequestType {
  ADDRESS
  SIZE
  COLOR
  PRODUCT
}

enum RefundType {
  CUSTOMER_RETURN
  ORDER_ADJUSTMENT
}